# Copy this file to .env for local (non-Docker) development, or set these
# as environment variables in your hosting provider (Render, Railway, Fly.io, etc.)

# Defaults to a local SQLite file if unset. In Docker Compose this is
# overridden to point at the bundled Postgres container.
DATABASE_URL=sqlite:///./lazo.db

# Comma-separated list of origins allowed to call this API (CORS).
# Include your deployed frontend's origin here, e.g. your Vercel domain.
ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# Optional regex to allow a whole family of origins (e.g. Vercel previews).
# ALLOWED_ORIGIN_REGEX=https://.*\.vercel\.app

# Public base URL of this backend, used to build absolute links to
# uploaded documents. Must be reachable from users' browsers.
PUBLIC_BASE_URL=http://localhost:8000
